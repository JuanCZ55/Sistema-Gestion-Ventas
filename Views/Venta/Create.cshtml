@model SistemaGestionVentas.Models.Venta

@{
  ViewData["Title"] = "Crear Venta";
  var action = ViewData["Action"]?.ToString() ?? "Create";
}

<div id="venta-app" class="row text-capitalize">
  <div class="col-md-12">
    <form asp-action="@action">
      <div asp-validation-summary="ModelOnly" class="text-danger"></div>

      @if (action == "Edit")
      {
        <input type="hidden" asp-for="Id" />
        <div class="form-group">
          <label asp-for="MotivoAnulacion" class="control-label">Motivo Anulación</label>
          <input asp-for="MotivoAnulacion" class="form-control" />
          <span asp-validation-for="MotivoAnulacion" class="text-danger"></span>
        </div>
      }

      <div class="row">
        <div class="form-group col">
          <label for="producto-select">Buscar Producto:</label>
          <select id="producto-select" class="form-control"></select>
        </div>

        <div class="form-group col">
          <label asp-for="MetodoPagoId" class="control-label">Métodos de Pago</label>
          <select asp-for="MetodoPagoId" class="form-control text-capitalize" asp-items="ViewBag.MetodoPagoId"></select>
        </div>
      </div>

      <table id="detalles-table" class="table table-striped">
        <thead>
          <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th style="width: 130px;">Cantidad</th>
            <th>Precio</th>
            <th>Subtotal</th>
            <th>Acción</th>
          </tr>
        </thead>

        <tbody>
          <tr v-for="item in detalles" :key="item.guid">
            <td>
              {{ item.idProducto }}

              <input type="hidden" name="Detalles.Index" :value="item.guid" />
              <input type="hidden" :name="`Detalles[${item.guid}].IdProducto`" :value="item.idProducto" />
            </td>

            <td>{{ item.nombre }}</td>

            <td>
              <input type="number" class="form-control" v-model.number="item.cantidad"
                     :name="`Detalles[${item.guid}].Cantidad`" />
            </td>

            <td>{{ item.precioUnitario }}</td>
            <td>{{ item.cantidad * item.precioUnitario }}</td>

            <td>
              <button type="button" class="btn btn-danger btn-sm" @@click="removerFila(item.guid)">
                Remover
              </button>
            </td>
          </tr>

          <tr v-if="detalles.length === 0">
            <td colspan="6" class="text-center text-muted">Sin productos agregados</td>
          </tr>
        </tbody>

        <tfoot>
          <tr>
            <td colspan="4"><strong>Total:</strong></td>
            <td>{{ total }}</td>
            <td></td>
          </tr>
        </tfoot>
      </table>

      <div class="d-flex justify-content-between mt-3">
        <a asp-action="Index" class="btn btn-secondary">Volver a Ventas</a>
        <input type="submit" value="@(action == "Edit" ? "Guardar Cambios" : "Crear")" class="btn btn-primary" />
      </div>
    </form>
  </div>
</div>

@section Scripts {
  <script>
                // Para edit o falla del create
                const detallesIniciales = @Html.Raw(Json.Serialize(ViewData["Detalles"] ?? new List<object>()));

                const { createApp } = Vue;

                const app = createApp({
                  data() {
                    return {
                      detalles: [],
                      productosCache: {},
                      tom: null
                    };
                  },

                  computed: {
                    total() {
                      return this.detalles.reduce((sum, d) => {
                        const cantidad = Number(d.cantidad) || 0;
                        const precio = Number(d.precioUnitario) || 0;
                        return sum + (cantidad * precio);
                      }, 0);
                    }
                  },

                  methods: {
                    generarGuid() {
                      return crypto.randomUUID();
                    },

                    async obtenerProducto(id) {
                      if (this.productosCache[id]) { return this.productosCache[id]; }

                      const resp = await fetch(`/api/productos/${id}`);
                      if (!resp.ok) {
                        showToast("danger", "Producto no encontrado"); }
                      const p = await resp.json();
                      this.productosCache[id] = p;
                      return p;
                    },

                    agregarFilaDesdeProducto(producto, cantidad = 1) {
                      // existe
                      const existente = this.detalles.find(
                        d => d.idProducto === producto.id
                      );

                      if (existente) {
                        //  se incrementa el mismo
                        existente.cantidad += Number(cantidad) || 1;
                      } else {
                        // agregar nuevo
                        this.detalles.push({
                          guid: this.generarGuid(),
                          idProducto: producto.id,
                          nombre: producto.nombre,
                          cantidad: Number(cantidad) || 1,
                          precioUnitario: Number(producto.precioVenta) || 0
                        });
                      }
                    },

                    async agregarProducto(id) {
                      if (!id) return;
                      try {
                        const p = await this.obtenerProducto(id);
                        this.agregarFilaDesdeProducto(p, 1);
                      } catch (e) {
                        if (window.showToast) {
                          window.showToast("danger", "Error obteniendo producto: " + e.message);
                        } else {
                          alert("Error obteniendo producto: " + e.message);
                        }
                      }
                    },

                    removerFila(guid) {
                      this.detalles = this.detalles.filter(x => x.guid !== guid);
                    },

                    async cargarDetallesExistentes() {
                      for (const d of detallesIniciales) {
                        try {
                          const p = await this.obtenerProducto(d.idProducto);
                          this.agregarFilaDesdeProducto(p, d.cantidad);
                        } catch (e) {
                          console.error("Error cargando producto existente:", e);
                        }
                      }
                    },

                    initTomSelect() {
                      const vm = this;

                      this.tom = new TomSelect("#producto-select", {
                        valueField: "id",
                        labelField: "nombre",
                        searchField: ["codigo", "nombre"],
                        persist: false,
                        cache: false,

                        load: function (query, callback) {
                          if (!query || query.length < 1) return callback([]);
                          fetch(`/api/productos/search?q=${encodeURIComponent(query)}`)
                            .then(r => r.json())
                            .then(data => callback(data))
                            .catch(() => callback([]));
                        },

                        onType: function () {
                          this.clearOptions();
                          this.lastQuery = null;
                        },

                        onBlur: function () {
                          this.clearOptions();
                          this.lastQuery = null;
                        },

                        // uso arrow para capturar el 'this' del componente Vue (vm)
                        onChange: id => {
                          if (!id) return;
                          vm.agregarProducto(id);

                          // limpiar seleccion en TomSelect (instancia en vm.tom)
                          if (vm.tom) {
                            vm.tom.clear();
                            vm.tom.clearOptions();
                          }
                        },

                        render: {
                          option: function (item, escape) {
                            return `<div>[${escape(item.codigo)}] ${escape(item.nombre)} — $${escape(
                              item.precioVenta
                            )}</div>`;
                          }
                        }
                      });
                    },


                  },

                  async mounted() {
                    this.initTomSelect();
                    await this.cargarDetallesExistentes();
                  },

                  beforeUnmount() {
                    if (this.tom) this.tom.destroy();
                  }
                });

                app.mount("#venta-app");
                
  </script>
}